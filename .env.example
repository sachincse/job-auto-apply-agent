# ============================================
# Job Auto-Apply Agent — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- Claude AI (required) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Adzuna Job Search API (free tier: 250 calls/day) ---
# Sign up: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# --- LinkedIn Credentials ---
# WARNING: Automating LinkedIn can get your account banned. Use at your own risk.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Telegram Bot (for reports & alerts) ---
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email / SMTP (for reports) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_TO=

# --- General ---
DRY_RUN=false
LOG_LEVEL=INFO
MAX_DAILY_APPLICATIONS=20
